# .env.example
# 服务
SERVER_PORT=8080
SERVER_MODE=debug

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=newshop
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=24h

# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 极验
GEETEST_ID=
GEETEST_KEY=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# CORS（逗号分隔多个来源）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
